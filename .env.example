# Copy this file to .env and fill in your keys

# Required if images.provider = runninghub (free daily credits at runninghub.ai)
RUNNINGHUB_API_KEY=your_runninghub_api_key_here

# Required if images.provider = replicate (~$0.003/image)
REPLICATE_API_TOKEN=your_replicate_token_here

# Required only if script.provider = claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# Required only if voice.provider = elevenlabs
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# YouTube credentials are handled via OAuth flow (see docs/COMPONENTS.md)
# Place your downloaded credentials.json at config/youtube_credentials.json
